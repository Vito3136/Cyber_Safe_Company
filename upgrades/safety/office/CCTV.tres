[resource]
script = ExtResource("1_mtsdj")
titolo = "Closed-Circuit Television (CCTV)"
descrizione = "Full-coverage cameras across the entire company, recording activity 24/7. From a security standpoint, physical surveillance acts both as a deterrent and as forensic evidence. It prevents unauthorized individuals from accessing sensitive areas and helps identify insider threats or social engineering attempts in person."
