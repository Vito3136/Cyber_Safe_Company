[resource]
script = ExtResource("1_indsb")
titolo = "CIS Controls - Level 3"
descrizione = "The highest tier of CIS compliance, targeting the most advanced and persistent threats. From a security standpoint, Level 3 is designed to defend against nation-state actors and highly organized criminal groups, implementing the most rigorous controls around incident response, penetration testing, and red team readiness."
upgrade_id = "cis_3"
required_id = "cis_2"
