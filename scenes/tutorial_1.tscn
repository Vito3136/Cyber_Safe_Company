[node name="Label2" type="Label" parent="VBoxContainer/HBoxContainer" unique_id=839074492]
layout_mode = 2
size_flags_horizontal = 3
theme_override_fonts/font = ExtResource("4_5dhqw")
theme_override_font_sizes/font_size = 23
text = "Welcome!
You have just acquired Cyber Safe Company, a promising manufacturer of smart devices: smart sockets, connected light bulbs, surveillance cameras and digital locks.
Your goal is to grow the company, optimise production, increase sales and reinvest profits to expand the business.

But be careful, running a technology company today is not just about manufacturing and selling. Your systems are connected, your data is valuable, and there are people out there who know it.

You'll need to carefully balance every choice: invest in production to increase revenue, but never neglect cybersecurity. Unlock and upgrade all your machinery, upgrade your network, protect your servers, and install monitoring systems.
Because in the end, a company that produces a lot but doesn't protect itself... is just a bigger target."
horizontal_alignment = 3
autowrap_mode = 2

